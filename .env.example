NODE_ENV=development
PORT=3001

# Dedicated MongoDB for calling service (recommended separate database)
MONGODB_URL=mongodb://127.0.0.1:27017/dharwinone_calling

# Must match dharwinone_backend JWT_SECRET so mobile/web tokens validate here
JWT_SECRET=your-jwt-secret-min-32-chars

# CORS — comma-separated origins (Expo dev, web app)
CORS_ORIGIN=http://localhost:8081,http://localhost:19006

# Public URL for local API references (mobile dev)
BACKEND_PUBLIC_URL=http://localhost:3001

# ngrok tunnel for Plivo webhooks + mobile app API (required for real PSTN calls in dev)
# 1. Run: ngrok http 3001
# 2. Copy the https://....ngrok-free.app (or .dev) URL — no path suffix
# 3. Set PLIVO_WEBHOOK_BASE_URL and BACKEND_PUBLIC_URL to that URL
# 4. Set TRUST_PROXY_HOPS=1
# 5. Update dharwinone_app/.env EXPO_PUBLIC_CALLING_API_URL to https://<ngrok-host>/v1
# PLIVO_WEBHOOK_BASE_URL=https://abc123.ngrok-free.app
# TRUST_PROXY_HOPS=1
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
PLIVO_PHONE_NUMBER=
# PLIVO_APP_ID=
# Verify Plivo webhook signatures (default: true in production, false in local dev)
# PLIVO_VERIFY_WEBHOOKS=true
